# .env.local

# disabled next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# Copilot API (client-side)
NEXT_PUBLIC_COPILOT_API_MODE=real
NEXT_PUBLIC_COPILOT_API_BASE_URL=https://your-api.example.com
NEXT_PUBLIC_COPILOT_API_TIMEOUT_MS=15000
# NOTE: NEXT_PUBLIC_* values are exposed to the browser. Use dev/test token only.
NEXT_PUBLIC_COPILOT_API_TOKEN=your-dev-token
